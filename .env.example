# ── Existing pipeline API keys ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Add authorised redirect URI: https://<your-railway-domain>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Auth ───────────────────────────────────────────────────────────────────────
# Any long random string — generate with: openssl rand -hex 32
JWT_SECRET=

# ── URLs ───────────────────────────────────────────────────────────────────────
# FastAPI backend (Railway domain)
BACKEND_URL=https://your-api.railway.app
# Next.js frontend (Vercel domain)
FRONTEND_URL=https://your-app.vercel.app

# ── Redis ──────────────────────────────────────────────────────────────────────
# Railway injects this automatically when you add the Redis plugin
REDIS_URL=redis://localhost:6379/0

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/app.db
